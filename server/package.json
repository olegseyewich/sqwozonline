{
  "name": "@concord/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev --name init",
    "db:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../.env -- prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^8.0.3",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "heic-convert": "^2.1.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "dotenv-cli": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
