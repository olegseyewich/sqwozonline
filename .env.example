# ─── Core ───────────────────────────────────────────────────────────────
NODE_ENV=development
SERVER_PORT=4000

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate strong secrets in production: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=900            # 15 minutes (seconds)
REFRESH_TOKEN_TTL=2592000       # 30 days (seconds)

# ─── Database: local SQLite (no external service) ────────────────────────
# Path is relative to server/prisma/. One file = the whole database.
DATABASE_URL="file:./dev.db"

# ─── Storage: local filesystem (unlimited file size, bounded by disk) ────
STORAGE_DIR=./uploads
# Optional S3/MinIO for production — leave blank to use local disk:
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=concord-media

# ─── Limits (the whole point: turned OFF / set very high) ────────────────
MAX_MESSAGE_LENGTH=100000       # 100k chars (DoS guard only)
MAX_UPLOAD_BYTES=0              # 0 = unlimited (bounded only by disk)

# ─── WebRTC voice/screen-share (ICE) ─────────────────────────────────────
# STUN is enough on the same network. For reliable cross-network calls, run
# coturn and set these; otherwise a free public TURN fallback is used.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN_URLS=turn:your-coturn-host:3478,turn:your-coturn-host:3478?transport=tcp
# TURN_USERNAME=concord
# TURN_PASSWORD=change-me
